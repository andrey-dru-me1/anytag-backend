# direnv configuration for anytag-backend
#
# Copy to .envrc and run 'direnv allow'
# See docs/DEVELOPMENT.md for detailed setup instructions

# Load Nix environment from flake.nix
use flake

# Load .env file if present
if [[ -f .env ]]; then
  dotenv .env
fi

# Cleaner output
export DIRENV_LOG_FORMAT=""

# Welcome message
echo "🔧 anytag-backend environment loaded via direnv"
