### Rust ###
# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Additional Rust artifacts
**/*.rlib
**/*.d
**/*.so
**/*.dylib
**/*.dll

# Rust coverage data
*.profraw
*.profdata

# Rust documentation
/target/doc/

# Rust incremental compilation
/target/debug/incremental/
/target/release/incremental/

# Cargo registry index
.cargo/registry/
.cargo/git/

### rust-analyzer ###
# Can be generated by other build systems other than cargo (ex: bazelbuild/rust_rules)
rust-project.json

# Rust analysis files
rust-analyzer/
.rust-analyzer/


### VisualStudioCode ###
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

### VisualStudioCode Patch ###
# Ignore all local history of files
.history
.ionide

### Nix ###
# Nix build results
result
result-*

# Nix garbage collection roots
/gc-roots
/gc-roots/

# Nix shell history
.nix-shell-*
.nix-shell

# Nix store symlinks
/store/
/store-*

# Nix profiles
/nix-profile
/nix-profiles/

# Nix development shells
shell.nix  # if not using flakes
default.nix

# Nix temporary files
*.nixos
*.darwin

### Direnv ###
# Direnv directory
.direnv/

# Direnv configuration files
direnv.toml
.direnv.toml

# Note: We use .envrc.template as a template for direnv configuration
# Copy it to .envrc for local use. .envrc is gitignored to keep local
# configurations out of version control.
.envrc

### Environment ###
# Environment variables
.env
.env.local
.env.*.local
.env.*.bak

# Local development environment files
.local.env
.dev.env

### Database ###
# Local database files
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal

# PostgreSQL data directory (if not using Docker)
postgres_data/
postgres-data/
pgdata/

# Database dumps
*.dump
*.sql.gz
*.backup

### Docker ###
# Docker Compose override files
docker-compose.override.yml
docker-compose.*.yml

# Docker build artifacts
.dockerignore
Dockerfile.local

# Docker volumes
docker-volumes/

### Development Tools ###
# Editor and IDE files
.idea/
*.swp
*.swo
*~
*.bak
*.tmp
*.temp

# Log files
*.log
logs/
log/

# Temporary directories
tmp/
temp/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Thumbnails
._*

# Files that might appear on external disk
.Spotlight-V100
.Trashes
